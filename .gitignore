# --- OS / editor cruft -----------------------------------------------------
.DS_Store
~$*

# --- Local tool settings ---------------------------------------------------
.claude/settings.local.json

# --- Pipeline intermediates ------------------------------------------------
# Everything in temp/ is regenerated by steps 03-06. Nothing here is a source
# of truth.
/temp/

# --- O*NET source data -----------------------------------------------------
# The three xlsx the pipeline reads (Abilities, Work Activities, Work Context)
# ARE committed for every data year, so a fresh clone runs offline. The raw/
# download cache is ignored: with seven data years the release zips would put
# ~320 MB in git (the 24.1 zip alone exceeds GitHub's 50 MB warning), so
# 01_download_onet.do instead re-downloads a zip only when a year's xlsx are
# missing, from
#   https://www.onetcenter.org/dl_files/database/db_<ver>_excel.zip
# (year -> ver map at the top of 01_download_onet.do).
/input/onet_*/raw/

# input/crosswalks/raw/ is deliberately NOT ignored wholesale. The BLS and KSH
# source files cannot be fetched automatically (BLS 403s to curl and Stata's
# copy; KSH publishes only a PDF), so they are committed - they are the only
# provenance for crosswalk legs 2-4. Ignore just the one file that the
# pipeline re-downloads on every run.
/input/crosswalks/raw/2019_to_SOC_Crosswalk.xlsx

# Stata leftovers
*.smcl
*.log
